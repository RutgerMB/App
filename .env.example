# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Optional: pre-created price ID (otherwise auto-created on first checkout)
# STRIPE_PRICE_ID=price_xxx

# Client URL for Stripe redirects (web checkout)
CLIENT_URL=http://localhost:5173

# Server port
PORT=3001

# Android emulator API (optional — defaults to http://10.0.2.2:3001)
# VITE_API_URL_NATIVE=http://10.0.2.2:3001

# Dev login bypass — LOCAL DEV ONLY (never set in App Store builds)
# VITE_ENABLE_DEV_LOGIN=true
# VITE_DEV_LOGIN_CODE=replock
# VITE_DEV_LOGIN_PASSWORD=dev123

# JWT for auth (required in production)
# JWT_SECRET=your-random-secret

# App Store review demo account (auto-created on server start)
# APP_REVIEW_EMAIL=review@replock.app
# APP_REVIEW_PASSWORD=ChooseAStrongReviewPassword1!

# iOS In-App Purchase product ID (App Store Connect)
# VITE_APPLE_PRODUCT_ID=replock_pro_monthly

# Legal URLs (optional — in-app /privacy and /terms work by default)
# VITE_PRIVACY_URL=https://replock.app/privacy
# VITE_TERMS_URL=https://replock.app/terms
# VITE_SUPPORT_EMAIL=support@replock.app

# --- Firebase (recommended for production auth & cloud sync) ---
# 1. Create a project at https://console.firebase.google.com
# 2. Enable Authentication → Email/Password
# 3. Create Firestore database (production mode, then add rules below)
# 4. Project settings → Your apps → Web app → copy config into VITE_FIREBASE_*
#
# Firestore rules (Firestore → Rules):
#   match /users/{userId} {
#     allow read, write: if request.auth != null && request.auth.uid == userId;
#   }
#
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
#
# Server: verify Firebase tokens for Stripe/Apple routes (optional but recommended)
# Download service account JSON from Firebase → Project settings → Service accounts
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or set GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccount.json
# Or FIREBASE_PROJECT_ID=your-project (when running on GCP with default credentials)
