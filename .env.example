# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Optional: pre-created price ID (otherwise auto-created on first checkout)
# STRIPE_PRICE_ID=price_xxx

# Client URL for Stripe redirects (web checkout)
CLIENT_URL=http://localhost:5173

# Server port
PORT=3001

# Android emulator API (optional — defaults to http://10.0.2.2:3001)
# VITE_API_URL_NATIVE=http://10.0.2.2:3001

# JWT for auth (change in production)
# JWT_SECRET=your-random-secret
