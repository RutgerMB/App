<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blocker_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/blocker_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/blocker_logo_bg"
        android:gravity="center"
        android:text="R"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blocker_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:textColor="@color/blocker_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blocker_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/blocker_text_muted"
        android:textSize="16sp" />

    <Button
        android:id="@+id/blocker_open_replock"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="36dp"
        android:backgroundTint="@color/blocker_button"
        android:text="@string/blocker_open_replock"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/blocker_go_home"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/blocker_button_secondary"
        android:text="@string/blocker_go_home"
        android:textAllCaps="false"
        android:textColor="#CCFFFFFF"
        android:textSize="16sp" />

</LinearLayout>
